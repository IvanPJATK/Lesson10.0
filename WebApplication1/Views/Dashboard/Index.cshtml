@model IEnumerable<WebApplication1.Models.UserNote>

@{
    ViewData["Title"] = "Your Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Welcome to Your Private Dashboard</h2>
    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger">Log Out</a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card p-3 shadow-sm">
            <h4>Add a Private Note</h4>
            <form asp-controller="Dashboard" asp-action="AddNote" method="post">
                <div class="form-group mb-2">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Content</label>
                    <textarea name="content" class="form-control" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-100">Save Note</button>
            </form>
        </div>
    </div>

    <div class="col-md-8">
        <h4>Your Notes</h4>
        @if (!Model.Any())
        {
            <div class="alert alert-info">You haven't written any private notes yet.</div>
        }
        else
        {
            @foreach (var note in Model)
            {
                <div class="card mb-3 shadow-sm border-start border-primary border-4">
                    <div class="card-body">
                        <h5 class="card-title">@note.Title</h5>
                        <p class="card-text">@note.Content</p>
                        <span class="text-muted small">Created: @note.CreatedAt.ToLocalTime().ToString("g")</span>
                    </div>
                </div>
            }
        }
    </div>
</div>